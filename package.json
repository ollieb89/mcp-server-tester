{
  "name": "@ollieb89/mcp-server-tester",
  "version": "1.0.0",
  "description": "GitHub Action + CLI to test MCP servers in CI: health checks, schema validation, tool/resource discovery, protocol compliance",
  "main": "dist/index.js",
  "bin": {
    "mcp-server-tester": "dist/bin/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "test": "jest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist/",
    "action.yml",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "mcp",
    "model-context-protocol",
    "github-actions",
    "testing",
    "ci-cd",
    "mcp-server",
    "validation",
    "developer-tools",
    "ai-agents",
    "protocol-testing"
  ],
  "author": "ollieb89",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ollieb89/mcp-server-tester"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^22.19.15",
    "jest": "^29.7.0",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "@actions/core": "^1.11.1",
    "@actions/github": "^6.0.1"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.ts"
    ],
    "collectCoverageFrom": [
      "src/**/*.ts",
      "!src/index.ts",
      "!src/bin/cli.ts",
      "!src/client.ts"
    ],
    "coverageThreshold": {
      "global": {
        "lines": 75
      }
    }
  }
}